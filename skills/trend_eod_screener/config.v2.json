{
  "skill": {
    "name": "trend_eod_screener",
    "version": "2.0.0-research",
    "category": "analysis",
    "author": "OpenClaw Team",
    "description": "趋势尾盘选股研究版：情绪过滤 + 主力意图过滤 + 次日触达回测"
  },
  "workspace": {
    "db_dir": "/root/.openclaw/workspace/data/db",
    "emotion_output_dir": "/root/.openclaw/workspace/data/db/output"
  },
  "research": {
    "lookback_months": 6,
    "top_n": 20,
    "buy_time_approx": "14:55",
    "hard_stop_loss_pct": -7.0,
    "take_profit_levels_pct": [3.0, 5.0, 8.0],
    "take_profit_sell_ratios": [0.35, 0.35, 0.30],
    "force_exit_next_day": true
  },
  "universe": {
    "exclude_st": true,
    "exclude_kcb": true,
    "exclude_bj": true,
    "min_turnover_amount": 80000000,
    "min_close": 3.0,
    "max_close": 120.0,
    "min_float_capital": 1500000000,
    "max_float_capital": 150000000000
  },
  "modes": {
    "trend": {
      "enabled": true,
      "weights": {
        "pattern": 0.25,
        "trend": 0.20,
        "capital": 0.15,
        "position": 0.10,
        "topic": 0.10,
        "limit_up": 0.10,
        "intent": 0.10
      }
    },
    "leader": {
      "enabled": true,
      "weights": {
        "pattern": 0.10,
        "trend": 0.15,
        "capital": 0.15,
        "position": 0.05,
        "topic": 0.20,
        "limit_up": 0.25,
        "intent": 0.10
      }
    }
  },
  "filters": {
    "emotion": {
      "enabled": true,
      "block_cycles": ["退潮期"],
      "penalty_cycles": ["高潮期"]
    },
    "intent": {
      "enabled": true,
      "allow_labels": ["强势吸筹", "偏多建仓", "多空分歧"],
      "block_labels": ["偏空出货", "出货陷阱"]
    }
  }
}
