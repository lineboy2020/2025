{
  "project": {
    "name": "ths-trend-eod-strategy",
    "version": "0.1.0",
    "timezone": "Asia/Shanghai"
  },
  "storage": {
    "primary": "duckdb",
    "duckdb_path": "/root/.openclaw/workspace/data/db/kline_eod.duckdb",
    "private_parquet_dir": "/root/.openclaw/workspace/projects/ths-trend-eod-strategy/data"
  },
  "data_sources": {
    "history": {
      "primary": "duckdb",
      "fallback": ["ths_sdk", "ths_http"],
      "allow_intraday_sdk": false
    },
    "realtime": {
      "primary": "ths_http",
      "fallback": ["akshare"],
      "allow_sdk": false
    },
    "snapshot": {
      "primary": "ths_http",
      "fallback": [],
      "allow_sdk": false
    },
    "hf": {
      "primary": "ths_http",
      "fallback": [],
      "allow_sdk": false
    }
  },
  "strategy": {
    "name": "trend_eod_realtime_v1",
    "mode": "tail_intraday_buy_nextday_sell",
    "buy_window": "14:30-14:50",
    "max_candidates": 2,
    "min_turnover_amount": 500000000,
    "max_intraday_gain_pct": 7.0,
    "min_intraday_gain_pct": -2.0,
    "tail_strength_threshold": 0.5,
    "stop_loss": 0.07,
    "take_profit": [0.03, 0.05, 0.08]
  },
  "market_regime": {
    "provider": "market-emotion",
    "enabled": true,
    "risk_on_emotions": ["发酵期", "高潮期"],
    "neutral_emotions": ["启动期"],
    "risk_off_emotions": ["冰点期", "退潮期"],
    "risk_on_max_candidates": 2,
    "neutral_max_candidates": 2,
    "risk_off_max_candidates": 0
  },
  "notification": {
    "channels": ["console", "markdown", "qq", "dingtalk"],
    "dedupe": true,
    "cooldown_minutes": 10
  }
}
